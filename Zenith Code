  background:var(--bg2);align-items:center;
  font-family:'Space Mono',monospace;font-size:0.75rem;
}
.order-row:last-child{border-bottom:none;}
.order-id-cell{color:var(--gray2);}
.order-method-cell{color:var(--gray2);}
.order-total-cell{color:var(--red);font-weight:700;}
.order-date-cell{color:var(--gray);}
.order-status-badge{
  display:inline-block;padding:0.25rem 0.6rem;
  font-size:0.62rem;letter-spacing:0.08em;font-weight:700;
  border:1px solid;
}
.status-pending{border-color:var(--gray);color:var(--gray);}
.status-in-progress{border-color:var(--cyan);color:var(--cyan);}
.status-completed{border-color:#00e5a0;color:#00e5a0;}
.status-cancelled{border-color:var(--gray);color:var(--gray);}
.order-expand{background:none;border:none;color:var(--gray);cursor:pointer;font-size:1rem;}
.order-detail-row{
  background:var(--bg3);border-bottom:1px solid var(--border);
  padding:1.25rem;display:none;
}
.order-detail-row.open{display:block;}
.od-label{font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;color:var(--gray);margin-bottom:0.3rem;}
.od-value{font-size:0.875rem;color:var(--gray2);}

/* LOGIN / AUTH */
.auth-page{
  display:flex;align-items:center;justify-content:center;
  min-height:calc(100vh - 56px);padding:2rem;
}
.auth-card{
  background:var(--bg3);border:1px solid var(--border);
  padding:2.5rem;width:100%;max-width:400px;
}
.auth-h{font-family:'Barlow Condensed',sans-serif;font-size:2rem;font-weight:900;margin-bottom:0.375rem;}
.auth-sub{font-size:0.875rem;color:var(--gray);margin-bottom:2rem;}
.auth-link{color:var(--cyan);cursor:pointer;}
.auth-link:hover{text-decoration:underline;}
.auth-error{
  background:rgba(229,57,53,0.1);border:1px solid var(--red);
  color:var(--red);padding:0.65rem 0.875rem;
  font-size:0.8125rem;margin-bottom:1rem;
}

/* ADMIN */
.admin-page{max-width:1000px;margin:0 auto;padding:3rem 2rem 5rem;}
.admin-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:2.5rem;}
.admin-tab{
  font-family:'Space Mono',monospace;font-size:0.7rem;letter-spacing:0.1em;
  padding:0.75rem 1.5rem;color:var(--gray);background:transparent;
  border:none;cursor:pointer;border-bottom:2px solid transparent;
  margin-bottom:-1px;transition:all .2s;
}
.admin-tab.active{color:var(--red);border-bottom-color:var(--red);}
.admin-tab:hover:not(.active){color:var(--white);}
.admin-section{display:none;}
.admin-section.active{display:block;}
.admin-h{font-family:'Barlow Condensed',sans-serif;font-size:3rem;font-weight:900;margin-bottom:0.5rem;}
.admin-eyebrow{font-family:'Space Mono',monospace;font-size:0.65rem;letter-spacing:0.14em;color:var(--red);margin-bottom:0.5rem;}
.refresh-btn{
  float:right;background:transparent;border:1px solid var(--border2);
  color:var(--gray2);padding:0.4rem 0.875rem;
  font-family:'Space Mono',monospace;font-size:0.65rem;letter-spacing:0.08em;
  cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:0.4rem;
}
.refresh-btn:hover{border-color:var(--cyan);color:var(--cyan);}
.user-list{border:1px solid var(--border);margin-top:1.5rem;}
.user-row{
  display:flex;align-items:center;gap:1rem;
  padding:1rem 1.25rem;border-bottom:1px solid var(--border);
  background:var(--bg3);
}
.user-row:last-child{border-bottom:none;}
.user-dot{width:10px;height:10px;border-radius:50%;background:var(--cyan);flex-shrink:0;}
.user-info{flex:1;}
.user-name{font-weight:600;font-size:0.9375rem;}
.user-email{font-size:0.8125rem;color:var(--gray);}
.user-role{
  font-family:'Space Mono',monospace;font-size:0.65rem;
  letter-spacing:0.1em;color:var(--gray2);margin-right:1rem;
}
.deactivate-btn{
  border:1px solid var(--red);color:var(--red);background:transparent;
  padding:0.3rem 0.75rem;font-family:'Space Mono',monospace;font-size:0.65rem;
  letter-spacing:0.08em;cursor:pointer;transition:all .2s;
  display:flex;align-items:center;gap:0.3rem;
}
.deactivate-btn:hover{background:var(--red);color:var(--white);}
/* admin orders */
.admin-orders-table{border:1px solid var(--border);margin-top:1.5rem;}
.ao-header{
  display:grid;grid-template-columns:100px 1fr 120px 180px 130px 36px;
  padding:0.65rem 1.25rem;background:var(--bg4);
  border-bottom:1px solid var(--border);
  font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;color:var(--gray);
}
.ao-row{
  display:grid;grid-template-columns:100px 1fr 120px 180px 130px 36px;
  padding:1rem 1.25rem;border-bottom:1px solid var(--border);
  background:var(--bg3);align-items:center;
  font-family:'Space Mono',monospace;font-size:0.72rem;
  transition:background .15s;
}
.ao-row:hover{background:var(--bg4);}
.ao-row:last-child{border-bottom:none;}
.ao-expand{background:none;border:none;color:var(--gray);cursor:pointer;font-size:0.9rem;}
.ao-detail{
  background:var(--bg4);border-bottom:1px solid var(--border);
  padding:1.25rem 1.5rem;display:none;
}
.ao-detail.open{display:grid;grid-template-columns:1fr 320px;gap:2rem;}
.ao-detail-left{}
.ao-detail-right{background:var(--bg3);border:1px solid var(--border);padding:1.25rem;}
.return-price-label{font-family:'Space Mono',monospace;font-size:0.65rem;color:var(--cyan);letter-spacing:0.1em;margin-bottom:0.5rem;}
.return-price-current{font-size:1rem;font-weight:700;color:var(--red);margin-bottom:0.875rem;}
.return-price-input{
  width:100%;background:var(--bg2);border:1px solid var(--border2);
  padding:0.75rem;color:var(--white);font-size:1rem;
  font-family:'Barlow',sans-serif;outline:none;margin-bottom:0.875rem;
}
.return-price-input:focus{border-color:var(--cyan);}
.status-btns{display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:0.75rem;}
.status-btn{
  padding:0.4rem 0.875rem;border:1px solid var(--border2);
  background:transparent;color:var(--gray2);
  font-family:'Space Mono',monospace;font-size:0.62rem;
  letter-spacing:0.08em;cursor:pointer;transition:all .15s;
}
.status-btn:hover,.status-btn.active-status{border-color:var(--cyan);color:var(--cyan);}
/* promo */
.promo-create-row{
  display:flex;gap:0.75rem;margin-bottom:1.5rem;align-items:center;
}
.promo-code-input{
  flex:1;background:var(--bg2);border:1px solid var(--border2);
  padding:0.75rem 1rem;color:var(--white);
  font-family:'Space Mono',monospace;font-size:0.8rem;letter-spacing:0.08em;
  outline:none;
}
.promo-code-input:focus{border-color:var(--cyan);}
.promo-amount-input{
  width:80px;background:var(--bg2);border:1px solid var(--border2);
  padding:0.75rem 0.5rem;color:var(--white);
  font-family:'Space Mono',monospace;font-size:0.8rem;text-align:center;
  outline:none;
}
.promo-amount-input:focus{border-color:var(--cyan);}
.promo-create-btn{
  background:var(--cyan);color:#001a14;border:none;
  padding:0.75rem 1.25rem;font-family:'Space Mono',monospace;
  font-size:0.7rem;letter-spacing:0.1em;cursor:pointer;font-weight:700;
  white-space:nowrap;
}
.promo-none{font-family:'Space Mono',monospace;font-size:0.7rem;color:var(--cyan);letter-spacing:0.1em;}
.promo-list{border:1px solid var(--border);margin-top:1rem;}
.promo-row-item{
  display:flex;align-items:center;gap:1rem;
  padding:0.875rem 1.25rem;border-bottom:1px solid var(--border);
  background:var(--bg3);font-family:'Space Mono',monospace;
}
.promo-row-item:last-child{border-bottom:none;}
.promo-code-name{font-size:0.85rem;font-weight:700;color:var(--white);flex:1;}
.promo-code-val{font-size:0.75rem;color:var(--red);}
.promo-delete-btn{
  background:none;border:1px solid var(--border2);color:var(--gray);
  padding:0.25rem 0.5rem;font-size:0.65rem;cursor:pointer;
  font-family:'Space Mono',monospace;letter-spacing:0.06em;
}
.promo-delete-btn:hover{border-color:var(--red);color:var(--red);}

/* TOAST */
#toast{
  position:fixed;bottom:2rem;right:2rem;z-index:9999;
  background:var(--bg3);border:1px solid var(--border);
  border-left:3px solid var(--cyan);
  padding:0.875rem 1.25rem;font-size:0.875rem;
  opacity:0;pointer-events:none;transform:translateY(8px);
  transition:all .3s;max-width:320px;
  font-family:'Space Mono',monospace;font-size:0.7rem;
}
#toast.show{opacity:1;transform:translateY(0);}
#toast.red{border-left-color:var(--red);}

/* TOC SIDEBAR */
#tocSidebar{
  position:fixed;top:56px;left:0;bottom:0;width:260px;
  background:rgba(9,9,15,0.97);border-right:1px solid var(--border);
  z-index:150;transform:translateX(-100%);transition:transform .25s;
  padding:2rem 1.5rem;overflow-y:auto;
}
#tocSidebar.open{transform:translateX(0);}
.toc-h{font-family:'Space Mono',monospace;font-size:0.65rem;letter-spacing:0.14em;color:var(--gray);margin-bottom:1.25rem;}
.toc-item{
  display:block;padding:0.6rem 0;
  font-family:'Space Mono',monospace;font-size:0.72rem;
  letter-spacing:0.08em;color:var(--gray2);
  border-bottom:1px solid var(--border);cursor:pointer;
  transition:color .15s;
}
.toc-item:hover{color:var(--cyan);}

@media(max-width:900px){
  .hero{grid-template-columns:1fr;padding:2rem;}
  .hero-3d{display:none;}
  .hero-upload-card{display:none;}
  .materials-grid{grid-template-columns:1fr;}
  .catalog-grid{grid-template-columns:repeat(2,1fr);}
  .custom-section{grid-template-columns:1fr;}
  .custom-right{border-left:none;border-top:1px solid var(--border);}
  .section,.section-sm{padding:3rem 1.5rem;}
  .catalog-header{padding:2rem 1.5rem 0;}
  .ao-header,.ao-row{grid-template-columns:80px 1fr 90px 110px;}
  .ao-header>:nth-child(5),.ao-header>:nth-child(6),
  .ao-row>:nth-child(5),.ao-row>:nth-child(6){display:none;}
  .ao-detail.open{grid-template-columns:1fr;}
}
</style>
