    const colorDots = item.colors.map(c=>`
      <div class="color-dot ${sel===c?'selected':''}" style="background:${COLORS[c]||c};" title="${c}" onclick="event.stopPropagation();selectColor('${item.id}','${c}')"></div>
    `).join('');
    return `
      <div class="cat-card" data-cat="${item.cat}">
        <div class="cat-img" style="background:linear-gradient(135deg,#0d1a2a,#1a2d45);">
          <div style="font-size:5rem;">${item.emoji}</div>
          ${badgeHTML}
