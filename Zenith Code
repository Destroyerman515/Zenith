            <div class="color-dots" id="dots-${item.id}">${colorDots}</div>
          </div>
          <button class="add-to-order-btn" onclick="addToCart('${item.id}')">ADD TO ORDER</button>
        </div>
      </div>`;
  }).join('');
}

