function selectColor(itemId, color){
  selectedColors[itemId] = color;
  // re-render just the dots
  const item = catalogItems.find(i=>i.id===itemId);
  if(!item) return;
  const dotsEl = document.getElementById('dots-'+itemId);
  if(dotsEl) dotsEl.innerHTML = item.colors.map(c=>`
    <div class="color-dot ${color===c?'selected':''}" style="background:${COLORS[c]||c};" title="${c}" onclick="event.stopPropagation();selectColor('${itemId}','${c}')"></div>
  `).join('');
}

function addToCart(itemId){
  const item = catalogItems.find(i=>i.id===itemId);
  if(!item) return;
  const color = selectedColors[itemId]||item.colors[0];
  const existing = cart.find(c=>c.id===itemId && c.color===color);
  if(existing){existing.qty++;}
  else {cart.push({id:itemId,name:item.name,emoji:item.emoji,price:item.price,weight:item.weight,color,qty:1,isCustom:false});}
  showToast(`${item.name} added to order!`);
}

