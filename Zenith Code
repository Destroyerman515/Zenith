/* MY ORDERS */
.my-orders-page{max-width:900px;margin:0 auto;padding:3rem 2rem 5rem;}
.orders-table{border:1px solid var(--border);}
.orders-header{
  display:grid;grid-template-columns:120px 1fr 120px 180px 130px 40px;
  padding:0.75rem 1.25rem;
  background:var(--bg3);border-bottom:1px solid var(--border);
  font-family:'Space Mono',monospace;font-size:0.65rem;
  letter-spacing:0.1em;color:var(--gray);
}
.order-row{
  display:grid;grid-template-columns:120px 1fr 120px 180px 130px 40px;
