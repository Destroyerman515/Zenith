// ===== CALCULATOR =====
function updateCalc(){
  const w=parseInt(document.getElementById('weightSlider').value)||1;
  document.getElementById('weightVal').textContent=w;
  document.getElementById('sizeHintWeight').textContent=w+'g';
  // size hint
  let label,name;
  if(w<=50){label='SMALL PRINT';name='Keychains, small charms';}
  else if(w<=150){label='SMALL PRINT';name='Phone cases, small housings';}
  else if(w<=350){label='MEDIUM PRINT';name='Figurines, desk items';}
  else if(w<=700){label='LARGE PRINT';name='Vases, large models';}
  else{label='EXTRA LARGE';name='Full-size models, enclosures';}
  document.getElementById('sizeHintLabel').textContent=label;
  document.getElementById('sizeHintName').textContent=name;
  const matCost=w*0.03;
  const base=1.00;
  const total=base+matCost;
  document.getElementById('calcPriceBig').textContent='$'+total.toFixed(2);
  document.getElementById('matLineLabel').textContent=`Material (${w}g × $0.03/g)`;
  document.getElementById('matLineVal').textContent='$'+matCost.toFixed(2);
  document.getElementById('totalLineVal').textContent='$'+total.toFixed(2);
}
updateCalc();

// Calc file upload
function handleCalcUpload(e){
  const f=e.target.files[0];
  if(!f) return;
  showToast(`${f.name} uploaded — estimating weight...`);
  // Estimate based on file size (rough heuristic: 1KB ≈ 0.5g)
  const estWeight = Math.min(1000,Math.max(1,Math.round(f.size/2048)));
  document.getElementById('weightSlider').value=estWeight;
  updateCalc();
  showToast(`Est. weight: ${estWeight}g based on file size.`);
}

// Drag and drop
['heroUploadDrop','calcUploadDrop'].forEach(id=>{
  const el=document.getElementById(id);
  if(!el) return;
  el.addEventListener('dragover',e=>{e.preventDefault();el.classList.add('dragover');});
  el.addEventListener('dragleave',()=>el.classList.remove('dragover'));
  el.addEventListener('drop',e=>{
    e.preventDefault(); el.classList.remove('dragover');
    const files=e.dataTransfer.files;
    if(!files.length) return;
    if(id==='heroUploadDrop'){
      const inp=document.getElementById('heroFileInput');
      // simulate
      showToast(`File uploaded: ${files[0].name} — DFM analysis running...`);
      cart.push({id:'upload-'+Date.now(),name:'Uploaded File',emoji:'📂',price:null,weight:null,color:'N/A',qty:1,isCustom:true,desc:`File: ${files[0].name}`});
    } else {
      showToast(`${files[0].name} uploaded — estimating weight...`);
      const estWeight=Math.min(1000,Math.max(1,Math.round(files[0].size/2048)));
      document.getElementById('weightSlider').value=estWeight;
      updateCalc();
    }
  });
});

