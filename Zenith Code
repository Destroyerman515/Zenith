  if(cart.length===0){
    el.innerHTML=`<div class="order-empty">
      <svg width="80" height="80" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
      <p>YOUR ORDER IS EMPTY</p>
      <button class="order-empty-btn" onclick="showPage('catalog')">BROWSE CATALOG</button>
    </div>`;
    return;
  }

  let subtotal=0;
  const itemsHTML = cart.map((item,i)=>{
    const priceStr = item.price!=null ? `$${(item.price*item.qty).toFixed(2)}` : 'TBD';
    if(item.price!=null) subtotal+=item.price*item.qty;
    return `<div class="order-item-card">
      <div class="order-item-emoji">${item.emoji}</div>
      <div class="order-item-info">
        <div class="order-item-name">${item.name}${item.isCustom?' <span style="font-size:0.75rem;color:var(--cyan);font-family:Space Mono,monospace;">[Custom]</span>':''} × ${item.qty}</div>
        <div class="order-item-meta">${item.isCustom&&item.desc?'CUSTOM DESCRIPTION: '+item.desc : 'Color: '+item.color+' · '+item.weight+'g'}</div>
      </div>
      <div class="order-item-price">${priceStr}</div>
      <button class="order-item-remove" onclick="removeFromCart(${i})">×</button>
    </div>`;
  }).join('');

  // Apply promo
  let discount=0, promoApplied='';
  const promoInput = document.getElementById('appliedPromo');
  if(promoInput){
    const code = promoInput.value.trim().toUpperCase();
    const p = promos.find(p=>p.code===code);
    if(p){discount=p.amount;promoApplied=code;}
  }
  const hasCustom = cart.some(c=>c.isCustom);
  const total = hasCustom ? 'TBD' : `$${Math.max(0,subtotal-discount).toFixed(2)}`;

  el.innerHTML=`
    ${itemsHTML}
    <div class="order-checkout-section">
      <div style="font-family:'Space Mono',monospace;font-size:0.65rem;letter-spacing:0.1em;color:var(--gray);margin-bottom:0.75rem;">PROMO CODE</div>
      <div class="promo-row">
        <input type="text" class="promo-input" id="appliedPromo" placeholder="ENTER CODE" style="text-transform:uppercase;">
        <button class="promo-btn" onclick="applyPromo()">APPLY</button>
      </div>
      ${discount>0?`<div style="font-family:'Space Mono',monospace;font-size:0.7rem;color:var(--cyan);margin-bottom:1rem;">✓ Code applied — $${discount.toFixed(2)} off</div>`:''}
      <div class="checkout-total">
        <span>ORDER TOTAL</span>
        <span class="price">${total}</span>
      </div>
      ${hasCustom?`<div style="font-family:'Space Mono',monospace;font-size:0.65rem;color:var(--gray);margin-top:0.5rem;">Custom items will be priced by our team within 24 hours.</div>`:''}
      <button class="btn-red" style="margin-top:1.25rem;" onclick="placeOrder()">PLACE ORDER →</button>
    </div>`;
}

function removeFromCart(i){
  cart.splice(i,1); renderOrder();
}

function applyPromo(){
  const input = document.getElementById('appliedPromo');
  if(!input) return;
  const code = input.value.trim().toUpperCase();
  const p = promos.find(p=>p.code===code);
  if(p){showToast(`Promo code applied: -$${p.amount.toFixed(2)}`);}
  else{showToast('Invalid promo code.','red');}
  renderOrder();
  // restore input value
  setTimeout(()=>{const inp2=document.getElementById('appliedPromo');if(inp2)inp2.value=code;},10);
}

function placeOrder(){
  if(cart.length===0) return;
  const hasCustom=cart.some(c=>c.isCustom);
  const id='#'+Math.random().toString(16).slice(2,8).toUpperCase();
  let subtotal=0; cart.forEach(c=>{if(c.price)subtotal+=c.price*c.qty;});
  const total=hasCustom?'TBD':'$'+subtotal.toFixed(2);
  const newOrder={id,method:'Pickup',total,date:new Date().toLocaleDateString(),status:'pending',items:[...cart]};
  myOrders.unshift(newOrder);
  orders.unshift({id,customer:currentUser?currentUser.email:'guest@email.com',total,date:new Date().toLocaleString(),status:'pending',method:'Pickup',items:[...cart],returnPrice:null});
  cart=[];
  showToast('Order placed! Check My Orders for status.');
  showPage('myorders');
}

