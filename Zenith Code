function toggleAODetail(id){
  const el=document.getElementById(id);
  if(el) el.classList.toggle('open');
}

function setOrderStatus(i,status){
  orders[i].status=status;
  // sync to myOrders
  const mo=myOrders.find(o=>o.id===orders[i].id);
  if(mo) mo.status=status;
  renderAdminOrders();
  showToast(`Order ${orders[i].id} status: ${status}`);
}

function setReturnPrice(i){
  const inp=document.getElementById('rp-'+i);
  const val=parseFloat(inp.value);
  if(isNaN(val)||val<0){showToast('Enter a valid price.','red');return;}
  orders[i].returnPrice=val;
  orders[i].total='$'+val.toFixed(2);
  const mo=myOrders.find(o=>o.id===orders[i].id);
  if(mo) mo.total='$'+val.toFixed(2);
  renderAdminOrders();
  showToast(`Return price set: $${val.toFixed(2)}`);
}

// ===== PROMOS =====
function createPromo(){
  const code=document.getElementById('promoCodeInput').value.trim().toUpperCase();
  const amount=parseFloat(document.getElementById('promoAmountInput').value)||0;
  if(!code){showToast('Enter a promo code.','red');return;}
  if(amount<1||amount>10){showToast('Amount must be between $1 and $10.','red');return;}
  if(promos.find(p=>p.code===code)){showToast('Code already exists.','red');return;}
  promos.push({code,amount});
  document.getElementById('promoCodeInput').value='';
  document.getElementById('promoAmountInput').value='5';
  renderPromos();
  showToast(`Promo code ${code} created!`);
}

function deletePromo(code){
  promos=promos.filter(p=>p.code!==code);
  renderPromos();
  showToast(`Promo code ${code} deleted.`,'red');
}

function renderPromos(){
  const el=document.getElementById('promoList');
  if(!el) return;
  if(promos.length===0){el.innerHTML='<div class="promo-none">NO CODES YET.</div>';return;}
  el.innerHTML=`<div class="promo-list">${promos.map(p=>`
    <div class="promo-row-item">
      <span class="promo-code-name">${p.code}</span>
      <span class="promo-code-val">-$${p.amount.toFixed(2)} off</span>
      <button class="promo-delete-btn" onclick="deletePromo('${p.code}')">DELETE</button>
    </div>
  `).join('')}</div>`;
}

// ===== TOAST =====
function showToast(msg,type=''){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.className=type==='red'?'show red':'show';
  clearTimeout(t._timeout);
  t._timeout=setTimeout(()=>t.classList.remove('show'),3200);
}

// Initial renders
renderCatalog('all');
updateNav();
renderPromos();
